# ─────────────────────────────────────────────────────────────────────────────
# Healthcare AI Assistant — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ─────────────────────────────────────────────────────────────────
# Get a free key from https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── LLM Settings (optional — defaults shown) ─────────────────────────────────
GROQ_MODEL=llama-3.1-8b-instant

# ── Embedding Settings (optional — defaults shown) ────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── ChromaDB Settings (optional — defaults shown) ─────────────────────────────
CHROMA_PERSIST_DIR=./vector_store
CHROMA_COLLECTION_NAME=healthcare_docs

# ── Document Ingestion Settings (optional — defaults shown) ───────────────────
DATA_DIR=./data
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RETRIEVAL_K=3

# ── Server Settings (optional — defaults shown) ───────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ── Frontend (set this in Streamlit Cloud Secrets for hosted deployment) ───────
# API_BASE_URL=https://your-backend-url.hf.space
